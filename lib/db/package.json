{
  "name": "@workspace/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./schema": "./src/schema/index.ts",
    "./zod": "./src/zod.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "0.8.3",
    "pg": "8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "catalog:",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
